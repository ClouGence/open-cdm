<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.console.web.dal.mapper.DmWorkerHeartbeatMapper">

    <resultMap id="heartBeatDO" type="com.clougence.clouddm.console.web.dal.model.DmWorkerHeartbeatDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="worker_seq_number" property="workerSeqNumber"/>
        <result column="worker_ip" property="workerIp"/>
        <result column="heartbeat_type" property="heartbeatType"/>
        <result column="worker_send_time" property="workerSendTime"/>
    </resultMap>

    <sql id="heartbeat">
        id,
        gmt_create,
        gmt_modified,
        worker_seq_number,
        worker_ip,
        heartbeat_type,
        worker_send_time
    </sql>

    <select id="queryHeartbeatByWsn" resultMap="heartBeatDO">
        SELECT
            <include refid="heartbeat"/>
        FROM
            dm_worker_heartbeat
        WHERE
            worker_seq_number = #{workerSeqNumber}
    </select>

    <update id="updateHeartbeatByWsn"
            parameterType="com.clougence.clouddm.console.web.dal.model.DmWorkerHeartbeatDO">
        UPDATE
            dm_worker_heartbeat
        SET
            worker_send_time = #{workerSendTime},
            heartbeat_type = #{heartbeatType}
        WHERE
            worker_seq_number = #{workerSeqNumber}
    </update>
</mapper>
