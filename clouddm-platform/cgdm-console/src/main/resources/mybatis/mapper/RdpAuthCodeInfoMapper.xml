<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.rdp.dal.mapper.authcode.RdpAuthCodeInfoMapper">

    <resultMap id="rdpAuthCodeInfoDO" type="com.clougence.rdp.dal.model.authcode.RdpAuthCodeInfoDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="auth_code" property="authCode"/>
        <result column="remind" property="remind"/>
        <result column="second_auth_code" property="secondAuthCode"/>
    </resultMap>

    <sql id="allColumn">
        rdp_auth_code_info.id id,
        rdp_auth_code_info.gmt_create gmt_create,
        rdp_auth_code_info.gmt_modified gmt_modified,
        rdp_auth_code_info.auth_code auth_code,
        rdp_auth_code_info.remind remind,
        rdp_auth_code_info.second_auth_code second_auth_code
    </sql>

    <select id="queryAuthCode" resultMap="rdpAuthCodeInfoDO">
        SELECT
        <include refid="allColumn"/>
        FROM
        rdp_auth_code_info
        ORDER BY gmt_modified DESC limit 1;
    </select>

</mapper>
