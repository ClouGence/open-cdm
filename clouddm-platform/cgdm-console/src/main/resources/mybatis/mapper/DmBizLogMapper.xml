<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.clouddm.console.web.dal.mapper.DmBizLogMapper">
    <resultMap id="autoExecJobDO" type="com.clougence.clouddm.console.web.dal.model.exec.DmBizLogDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="depend_on_biz_id" property="dependOnBizId"/>
        <result column="depend_on_biz_type" property="dependOnBizType"/>
        <result column="content" property="content"/>
        <result column="log_level" property="logLevel"/>
    </resultMap>

    <sql id="logDO">
        id,
        gmt_create,
        gmt_modified,
        depend_on_biz_id,
        depend_on_biz_type,
        content,
        log_level
    </sql>

    <select id="queryListByBizId" resultType="com.clougence.clouddm.console.web.dal.model.exec.DmBizLogDO">
        select
            <include refid="logDO"/>
        from
            dm_biz_log
        where
            depend_on_biz_id = #{bizId}
    </select>

    <select id="queryListByBizIdAndType" resultMap="autoExecJobDO">
        select
            <include refid="logDO"/>
        from
            dm_biz_log
        where
            depend_on_biz_id = #{bizId}
            depend_on_biz_type = #{bizType,javaType=com.clougence.clouddm.console.web.dal.enumeration.DmLogDependBizType}
    </select>
</mapper>
