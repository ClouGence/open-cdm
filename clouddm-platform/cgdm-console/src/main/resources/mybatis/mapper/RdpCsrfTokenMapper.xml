<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clougence.rdp.dal.mapper.RdpCsrfTokenMapper">

    <resultMap id="rdpCsrfTokenDO" type="com.clougence.rdp.dal.model.RdpCsrfTokenDO">
        <result column="id" property="id"/>
        <result column="gmt_create" property="gmtCreate"/>
        <result column="gmt_modified" property="gmtModified"/>
        <result column="token" property="token"/>
        <result column="jump_url" property="jumpUrl"/>
        <result column="secret_token" property="secretToken"/>
    </resultMap>

    <sql id="rdpCsrfToken">
        id,
        gmt_create,
        gmt_modified,
        token,
        jump_url,
        secret_token
    </sql>

    <select id="queryByToken" resultMap="rdpCsrfTokenDO">
        select <include refid="rdpCsrfToken"/>
        from rdp_csrf_token
        where token = #{token}
        limit 1
    </select>

    <delete id="deleteByToken">
        delete from rdp_csrf_token where token = #{token}
    </delete>

    <delete id="deleteBeforeTime">
        delete from rdp_csrf_token where gmt_modified &lt;= #{date}
    </delete>

    <update id="updateToken">
        update rdp_csrf_token
        set
            gmt_modified = now(),
            jump_url     = #{data.jumpUrl},
            secret_token = #{data.secretToken}
        where
            token = #{token}
    </update>
</mapper>
